        "jsCode": "return items.map(item => {\n  const data = item.json;\n  let identifier = null;\n\n  if (data.linkedin_profile) {\n    if (data.linkedin_profile.includes('/in/')) {\n      identifier = data.linkedin_profile.split('/in/')[1].replace('/', '');\n    } else {\n      identifier = data.linkedin_profile; // already an identifier\n    }\n  }\n\n  return {\n    json: {\n      name: data.name,\n      \n      linkedin_identifier: identifier\n    }\n  };\n});\n"
      },
