    {
      "parameters": {
        "jsCode": "const WORK_START = 9;\nconst WORK_END = 17;\nconst MIN_WORKING_RETURN = 0.01;\n\nconst inputTime = $json.currentDate ;\n// Parse date\nconst now = new Date(inputTime);\n\n// Extract timezone offset from ISO (+05:30 → 330 minutes)\nconst offsetMatch = inputTime.match(/([+-]\\d{2}):(\\d{2})$/);\nconst offsetMinutes = offsetMatch\n  ? (parseInt(offsetMatch[1]) * 60 + Math.sign(parseInt(offsetMatch[1])) * parseInt(offsetMatch[2]))\n  : 0;\n\n// Get \"local\" hour based on input timezone\nconst localMinutes =\n  now.getUTCHours() * 60 +\n  now.getUTCMinutes() +\n  offsetMinutes;\n\nconst localHour = Math.floor(localMinutes / 60) % 24;\n\n// If within working hours\nif (localHour >= WORK_START && localHour < WORK_END) {\n  return [{\n    json: {\n      waitHours: MIN_WORKING_RETURN\n    }\n  }];\n}\n\n// Calculate next 9 AM in same timezone\nconst target = new Date(now);\n\n// Before 9 AM → today 9 AM\nif (localHour < WORK_START) {\n  target.setUTCHours(WORK_START - offsetMinutes / 60, 0, 0, 0);\n}\n// After 5 PM → next day 9 AM\nelse {\n  target.setUTCDate(target.getUTCDate() + 1);\n  target.setUTCHours(WORK_START - offsetMinutes / 60, 0, 0, 0);\n}\n\nconst waitMs = target - now;\nconst waitHours = +(waitMs / (1000 * 60 * 60)).toFixed(2);\n\nreturn [{\n  json: {\n    waitHours\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
